{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amcor.internal/autoflow/automation-ir.schema.json",
  "title": "Amcor AutoFlow Automation IR",
  "description": "Engine-agnostic intermediate representation of an automation. Claude produces this; the agent interprets it. Start the action vocabulary small and grow it deliberately.",
  "type": "object",
  "required": ["name", "schemaVersion", "trigger", "steps"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "schemaVersion": { "type": "integer", "const": 1 },
    "description": { "type": "string" },
    "trigger": { "$ref": "#/$defs/trigger" },
    "variables": {
      "type": "array",
      "items": { "$ref": "#/$defs/variable" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "trigger": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["manual", "schedule", "email_received", "file_created", "webhook"]
        },
        "source": { "type": ["string", "null"], "description": "e.g. outlook, sharepoint" },
        "schedule": { "type": ["string", "null"], "description": "cron expression when type=schedule" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        }
      }
    },
    "condition": {
      "type": "object",
      "required": ["field", "op", "value"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "op": { "type": "string", "enum": ["equals", "contains", "startsWith", "matches", "gt", "lt"] },
        "value": {}
      }
    },
    "variable": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["string", "number", "boolean", "date"] },
        "from": { "type": ["string", "null"], "description": "provenance, e.g. email_body_extract, constant, prompt_user" },
        "value": { "description": "literal default when from=constant" }
      }
    },
    "step": {
      "type": "object",
      "required": ["id", "order", "action", "rawInstruction"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "integer", "minimum": 1 },
        "action": {
          "type": "string",
          "description": "Controlled vocabulary. Web actions + native Windows/Office actions.",
          "enum": [
            "open_application",
            "navigate",
            "click",
            "type_text",
            "select_option",
            "read_email",
            "extract",
            "wait",
            "condition",
            "loop",
            "api_call",
            "open_file",
            "save_file",
            "read_cell",
            "read_range",
            "set_cell",
            "write_range",
            "press_keys",
            "focus_window"
          ]
        },
        "target": {
          "type": ["object", "null"],
          "description": "What the action acts on. Fields used depend on action. Omit or set to {} when not applicable — never null.",
          "additionalProperties": true,
          "properties": {
            "app": { "type": ["string", "null"], "description": "e.g. chrome, outlook. Only set for open_application." },
            "url": { "type": ["string", "null"] },
            "selector": { "type": ["string", "null"], "description": "CSS/role selector for web steps" },
            "label": { "type": ["string", "null"], "description": "human-visible label; fallback for web, window title for focus_window" },
            "file": { "type": ["string", "null"], "description": "path to a local file; used by open_file, read_cell, read_range, set_cell, write_range" },
            "sheet": { "type": ["string", "null"], "description": "worksheet/tab name; used by Excel actions; omit for single-sheet files" }
          }
        },
        "params": {
          "type": "object",
          "description": "Action-specific arguments, e.g. {\"text\": \"{{requestor}}\"} for type_text.",
          "additionalProperties": true
        },
        "rawInstruction": {
          "type": "string",
          "description": "Original human text for this step. Provenance; never dropped."
        },
        "assetRefs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "object keys of authoring screenshots attached to this step"
        },
        "needsClarification": { "type": "boolean", "default": false },
        "clarificationQuestion": {
          "type": ["string", "null"],
          "description": "Set by Claude when needsClarification is true."
        }
      }
    }
  }
}
