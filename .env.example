# Copy to .env (same folder) and fill in. Never commit .env.

# Postgres
POSTGRES_USER=autoflow
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=autoflow

# MinIO (object storage for step screenshots)
MINIO_ROOT_USER=autoflow
MINIO_ROOT_PASSWORD=change-me-strong

# Anthropic / Claude API (used by the backend to compile steps -> IR)
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret the local agent uses to register with the backend.
# Put the same value in agent/appsettings.json -> Agent:Token
AGENT_SHARED_TOKEN=dev-agent-token
